from app.utils.responses import success_response, error_response
from app.controllers.users_controller import get_user
from app.exceptions.exceptions import BusinessException
import logging

logger = logging.getLogger(__name__)

def route(event):
    logger.info("route() start")

    method = event["httpMethod"]
    path = event["path"]

    logger.info(f"method={method}")
    logger.info(f"path={path}")

    if method == "GET" and path == "/kk":

        query = event.get("queryStringParameters") or {}
        user_id = int(query.get("id"))
        data = get_user(user_id)
        logger.info("route() end")
        return success_response(data)

    return {
        "statusCode": 404,
        "body": "not found"
    }
